# Copy to .env.local for local development. No secrets belong in this file.

# ── Database ──────────────────────────────────────────────────────────────────
# Set to a PostgreSQL/Supabase pooler URL to use Postgres. Leave unset to use the
# in-process PGlite (WASM Postgres) file DB under ./.pglite for local dev/tests.
# DATABASE_URL="postgres://user:pass@host:6543/postgres"

# ── Auth (single-password gate) ───────────────────────────────────────────────
# Auth is OFF until APP_PASSWORD is set. When set, every route except /login is
# gated by proxy.ts.
APP_USERNAME="admin"
# APP_PASSWORD="change-me"
# SECRET_KEY="change-me-to-a-long-random-string"
